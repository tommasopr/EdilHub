<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EdilControl PRO | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { background-color: #0a0a0a; color: #f3f4f6; font-family: 'Inter', sans-serif; }
        .neon-border { border: 1px solid rgba(204, 255, 0, 0.2); }
        .bg-card { background-color: #151515; border: 1px solid #262626; }
        .text-neon { color: #ccff00; }
        .bg-neon { background-color: #ccff00; }
        .shadow-neon { shadow-blur: 15px; shadow-color: rgba(204, 255, 0, 0.4); }
    </style>
</head>
<body class="p-6">

    <div class="max-w-7xl mx-auto flex justify-between items-center mb-8">
        <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-neon rounded flex items-center justify-center">
                <span class="text-black font-black text-xl">E</span>
            </div>
            <div>
                <h1 class="text-xl font-black tracking-widest uppercase italic">EDIL<span class="text-neon text-2xl">CONTROL</span></h1>
                <p class="text-[10px] text-gray-500 tracking-[0.3em] uppercase">Advanced Construction Management</p>
            </div>
        </div>
        <div class="text-right">
            <div class="inline-block px-3 py-1 rounded-full border border-gray-800 text-[10px] font-bold uppercase tracking-widest">
                <span class="inline-block w-2 h-2 bg-neon rounded-full mr-2 animate-pulse"></span> Sistema Live
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">
        
        <div class="md:col-span-8 space-y-6">
            
            <div class="bg-card rounded-2xl p-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-sm font-bold uppercase tracking-widest flex items-center gap-2">
                        <span class="text-neon">/</span> Cantieri Attivi
                    </h2>
                    <button class="text-[10px] text-neon border border-neon/30 px-3 py-1 rounded hover:bg-neon hover:text-black transition">Vedi Tutti</button>
                </div>
                
                <div class="space-y-6">
                    <div class="group cursor-pointer">
                        <div class="flex justify-between text-sm mb-2">
                            <span class="font-bold">Villa Modern - Lotto A</span>
                            <span class="text-neon">65%</span>
                        </div>
                        <div class="w-full bg-gray-900 h-1.5 rounded-full overflow-hidden">
                            <div class="bg-neon h-full shadow-neon" style="width: 65%"></div>
                        </div>
                        <div class="flex justify-between mt-2 text-[10px] text-gray-500 uppercase italic">
                            <span>Inizio: 12 Gen 2026</span>
                            <span>Consegna: 15 Set 2026</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-sm font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
                        <span class="text-neon">/</span> Risorse Umane
                    </h2>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between p-3 bg-black/40 rounded-lg border border-gray-800">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-gray-800 rounded-full border border-neon/50"></div>
                                <span class="text-sm">Matteo Sereni</span>
                            </div>
                            <span class="text-[10px] bg-neon/10 text-neon px-2 py-1 rounded">Cantiere 1</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-black/40 rounded-lg border border-gray-800">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-gray-800 rounded-full"></div>
                                <span class="text-sm">Marco Donati</span>
                            </div>
                            <span class="text-[10px] text-gray-500">Pausa</span>
                        </div>
                    </div>
                </div>

                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-sm font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
                        <span class="text-neon">/</span> Attrezzatura
                    </h2>
                    <div class="grid grid-cols-2 gap-3 text-center">
                        <div class="p-3 bg-black/40 rounded-lg border border-gray-800 group hover:border-neon/40 transition">
                            <p class="text-[10px] text-gray-500 uppercase">Gru Potain</p>
                            <p class="text-xs font-bold text-neon mt-1 italic uppercase">In Uso</p>
                        </div>
                        <div class="p-3 bg-black/40 rounded-lg border border-gray-800">
                            <p class="text-[10px] text-gray-500 uppercase">Escavatore J1</p>
                            <p class="text-xs font-bold text-gray-400 mt-1 italic uppercase">Garage</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="md:col-span-4 space-y-6">
            
            <div class="bg-card rounded-2xl p-6 border-l-4 border-l-neon">
                <h2 class="text-sm font-bold uppercase tracking-widest mb-4">Problematiche</h2>
                <div class="space-y-4">
                    <div class="p-3 bg-red-900/10 border border-red-900/30 rounded">
                        <p class="text-[10px] text-red-500 font-bold uppercase">Urgente</p>
                        <p class="text-xs mt-1 italic">Ritardo fornitura cemento - Lotto A</p>
                    </div>
                    <div class="p-3 bg-yellow-900/10 border border-yellow-700/30 rounded">
                        <p class="text-[10px] text-yellow-500 font-bold uppercase">Avviso</p>
                        <p class="text-xs mt-1 italic">Guasto generatore segnalato</p>
                    </div>
                </div>
            </div>

            <div class="bg-card rounded-2xl p-6">
                <h2 class="text-sm font-bold uppercase tracking-widest mb-4 italic">Costi Mensili</h2>
                <div class="text-3xl font-black mb-4">€ 142<span class="text-neon">.</span>500</div>
                <div class="flex items-end gap-1 h-24">
                    <div class="flex-1 bg-gray-800 h-1/2"></div>
                    <div class="flex-1 bg-gray-800 h-2/3"></div>
                    <div class="flex-1 bg-gray-800 h-1/3"></div>
                    <div class="flex-1 bg-neon h-full shadow-[0_0_10px_rgba(204,255,0,0.3)]"></div>
                    <div class="flex-1 bg-gray-800 h-3/4"></div>
                </div>
                <div class="flex justify-between mt-4 text-[9px] text-gray-500 uppercase tracking-widest italic font-bold">
                    <span>Gen</span><span>Feb</span><span>Mar</span><span>Apr</span><span>Mag</span>
                </div>
            </div>
        </div>

    </div>

    <footer class="max-w-7xl mx-auto mt-12 pt-6 border-t border-gray-900 flex justify-between items-center text-[10px] text-gray-600 tracking-widest uppercase italic">
        <span>©️ 2026 EDILCONTROL PROPRIETARY SYSTEM</span>
        <span>Lat: 40.84 - Long: 14.37</span>
    </footer>

</body>
</html>
